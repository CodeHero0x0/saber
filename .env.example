# Jira：L2 预览显示 ACCOUNT_ID，API token 只在执行阶段读取。
JIRA_BASE_URL="https://jira.example.com"
JIRA_ACCOUNT_ID="your-jira-account-id"
JIRA_API_TOKEN=""

# GitLab：ACCOUNT_ID 用于 L2 预览，token 不要提交到 Git。
GITLAB_BASE_URL="https://gitlab.example.com"
GITLAB_ACCOUNT_ID="your-gitlab-account-id"
GITLAB_API_TOKEN=""

# 业务仓 push 使用本机 Git credential helper 或 SSH agent。
GIT_PUSH_ACCOUNT_ID="your-git-account-id"

# 团队 MCP 命令；不使用时留空。
MYSQL_MCP_COMMAND=""
IDEA_MCP_COMMAND=""
